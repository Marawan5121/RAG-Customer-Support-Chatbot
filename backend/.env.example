# ---------------------------------------------------------------------------
# Backend environment variables (copy to .env and fill in real values)
# ---------------------------------------------------------------------------

# --- General ---
APP_NAME=Customer Support RAG Chatbot
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Azure AI Search (vector + BM25 hybrid retrieval with semantic ranking) ---
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<your-admin-or-query-key>
AZURE_SEARCH_INDEX_NAME=support-knowledge-index
AZURE_SEARCH_SEMANTIC_CONFIG=mySemanticConfig
AZURE_SEARCH_VECTOR_FIELD=content_vector
AZURE_SEARCH_TOP_K=4

# --- Azure Cosmos DB (session & message chat history) ---
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-primary-key>
COSMOS_DATABASE=support-chat
COSMOS_SESSIONS_CONTAINER=sessions
COSMOS_MESSAGES_CONTAINER=messages

# --- Azure Cache for Redis (response caching) ---
# Local dev: host=redis, port=6379, ssl=false
# Azure Cache for Redis: host=<name>.redis.cache.windows.net, port=6380, ssl=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=3600

# --- Google Generative AI (Gemini 1.5 Flash + 768-dim embeddings) ---
GOOGLE_API_KEY=<your-google-ai-studio-key>
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
